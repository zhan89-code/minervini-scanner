# Copy to .env for local overrides, or set as environment variables in
# your deploy platform (Railway, Render, Fly.io, etc.).

# Comma-separated list of frontend origins allowed to call this API.
# Omit for local dev -- defaults to http://localhost:5173.
ALLOWED_ORIGINS=https://your-frontend.vercel.app

# Nightly scan schedule (UTC). Defaults: 21:00, Mon-Fri (after US market close).
NIGHTLY_SCAN_HOUR=21
NIGHTLY_SCAN_MINUTE=0
NIGHTLY_SCAN_DAYS=mon-fri

# Path to the SQLite file. Omit for local dev -- defaults to backend/scanner.db.
# On a host with a persistent volume, point this at the mounted path so the
# database survives redeploys (e.g. Railway volume mounted at /data).
SCANNER_DB_PATH=/data/scanner.db
